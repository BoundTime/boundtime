# Supabase (für DB + Auth)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# E-Mails für Cuckymode (Bestätigung + Passwort vergessen)
# Eine der beiden Varianten eintragen:

# --- Option A: IONOS (oder anderes SMTP) – gleicher Versand wie Registrierung in Supabase ---
# In Supabase: Authentication → SMTP mit IONOS-Daten eintragen (für Registrierungs-Mails).
# Hier dieselben Zugangsdaten für Cuckymode-Mails (Absender = deine IONOS-E-Mail):
# Wie in Supabase (Authentication → SMTP): Port 465, secure
# SMTP_HOST=smtp.ionos.de
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=kontakt@boundtime.de
# SMTP_PASS=dein-passwort-fuer-dieses-postfach
# SMTP_FROM=kontakt@boundtime.de

# --- Option B: Resend (API) ---
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=noreply@deine-domain.de
